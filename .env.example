# Backend API Key (for frontend -> backend authentication)
# For development: use any string like 'dev-test-key-12345'
# For production: generate a strong random key using: openssl rand -hex 32
AIRRA_API_KEY=dev-test-key-12345

# Groq API Key
# Get your API key from: https://console.groq.com/keys
AIRRA_OPENAI_API_KEY=your_groq_api_key_here

# PostgreSQL password (CRIT-4)
# Development default is 'airra' (see docker-compose.yml fallback).
# For production: generate with: openssl rand -hex 16
POSTGRES_PASSWORD=airra

# Grafana admin password (HIGH-5)
# REQUIRED — no fallback. Generate with: openssl rand -hex 16
GRAFANA_PASSWORD=change_me_before_running
